#!/usr/bin/env python
import os
import subprocess
import sys

from methods import print_error

libname = "llama_cpp_provider"

# ---------------------------------------------------------------------------
# zig cc wrapper scripts
# ---------------------------------------------------------------------------
# CMake (and most build tools) cannot handle a compiler command with a space
# (e.g. "zig cc").  We generate tiny shell wrappers at configure time so that
# both CMake and SCons can refer to a single path.

ZIG_WRAPPER_DIR = os.path.abspath(".zig-wrappers")


def _write_wrapper(path, inner_cmd):
    os.makedirs(ZIG_WRAPPER_DIR, exist_ok=True)
    with open(path, "w") as f:
        f.write('#!/bin/sh\nexec {} "$@"\n'.format(inner_cmd))
    os.chmod(path, 0o755)


ZIG_CC = os.path.join(ZIG_WRAPPER_DIR, "zig-cc")
ZIG_CXX = os.path.join(ZIG_WRAPPER_DIR, "zig-c++")
ZIG_AR = os.path.join(ZIG_WRAPPER_DIR, "zig-ar")

_write_wrapper(ZIG_CC, "zig cc")
_write_wrapper(ZIG_CXX, "zig c++")
_write_wrapper(ZIG_AR, "zig ar")

# ---------------------------------------------------------------------------
# llama.cpp static-library build via CMake
# ---------------------------------------------------------------------------
LLAMA_SRC_DIR = os.path.abspath("vendor/llama.cpp")
LLAMA_BUILD_DIR = os.path.abspath("vendor/llama.cpp/build-static")


def build_llama_static():
    """Configure + build llama.cpp as a set of static libraries using zig cc."""
    os.makedirs(LLAMA_BUILD_DIR, exist_ok=True)

    cmake_configure = [
        "cmake",
        "-S",
        LLAMA_SRC_DIR,
        "-B",
        LLAMA_BUILD_DIR,
        "-DCMAKE_C_COMPILER={}".format(ZIG_CC),
        "-DCMAKE_CXX_COMPILER={}".format(ZIG_CXX),
        "-DCMAKE_AR={}".format(ZIG_AR),
        "-DBUILD_SHARED_LIBS=OFF",
        "-DLLAMA_BUILD_TESTS=OFF",
        "-DLLAMA_BUILD_EXAMPLES=OFF",
        "-DLLAMA_BUILD_TOOLS=OFF",
        "-DLLAMA_BUILD_COMMON=OFF",
        "-DLLAMA_BUILD_SERVER=OFF",
        "-DCMAKE_BUILD_TYPE=Release",
    ]

    sentinel = os.path.join(LLAMA_BUILD_DIR, ".llama_built")
    if not os.path.exists(sentinel):
        print("-- Configuring llama.cpp (static, zig cc) ...")
        subprocess.check_call(cmake_configure)
        print("-- Building llama.cpp ...")
        ncpu = os.cpu_count() or 4
        subprocess.check_call(
            ["cmake", "--build", LLAMA_BUILD_DIR, "--parallel", str(ncpu)]
        )
        open(sentinel, "w").close()
    else:
        print("-- llama.cpp already built (delete {} to rebuild)".format(sentinel))


build_llama_static()

# Paths to the four static libs produced by the build
LLAMA_STATIC_LIBS = [
    os.path.join(LLAMA_BUILD_DIR, "src", "libllama.a"),
    os.path.join(LLAMA_BUILD_DIR, "ggml", "src", "libggml.a"),
    os.path.join(LLAMA_BUILD_DIR, "ggml", "src", "libggml-base.a"),
    os.path.join(LLAMA_BUILD_DIR, "ggml", "src", "libggml-cpu.a"),
]

# ---------------------------------------------------------------------------
# godot-cpp / SCons environment setup
# ---------------------------------------------------------------------------
localEnv = Environment(tools=["default"], PLATFORM="")

# Build profiles can be used to decrease compile times.
# You can either specify "disabled_classes", OR
# explicitly specify "enabled_classes" which disables all other classes.
# Modify the example file as needed and uncomment the line below or
# manually specify the build_profile parameter when running SCons.

# localEnv["build_profile"] = "build_profile.json"

customs = ["custom.py"]
customs = [os.path.abspath(path) for path in customs]

opts = Variables(customs, ARGUMENTS)
opts.Update(localEnv)

Help(opts.GenerateHelpText(localEnv))

env = localEnv.Clone()

if not (os.path.isdir("vendor/godot-cpp") and os.listdir("vendor/godot-cpp")):
    print_error("""vendor/godot-cpp is not available within this folder, as Git submodules haven't been initialized.
Run the following command to download godot-cpp:

    git submodule update --init --recursive""")
    sys.exit(1)

# Use zig cc/c++ as the compiler for the extension as well, so the same
# toolchain is used throughout (avoids ABI mismatches on Linux).
env["CC"] = ZIG_CC
env["CXX"] = ZIG_CXX
env["AR"] = ZIG_AR
env["RANLIB"] = ZIG_AR  # zig ar handles ranlib indexing

env = SConscript("vendor/godot-cpp/SConstruct", {"env": env, "customs": customs})

# ---------------------------------------------------------------------------
# Extension sources
# ---------------------------------------------------------------------------
env.Append(
    CPPPATH=[
        "src/",
        os.path.join(LLAMA_SRC_DIR, "include"),  # llama.h / llama-cpp.h
        os.path.join(LLAMA_SRC_DIR, "ggml", "include"),  # ggml.h and friends
    ]
)

sources = Glob("src/*.cpp")

if env["target"] in ["editor", "template_debug"]:
    try:
        doc_data = env.GodotCPPDocData(
            "src/gen/doc_data.gen.cpp", source=Glob("doc_classes/*.xml")
        )
        sources.append(doc_data)
    except AttributeError:
        print("Not including class reference as we're targeting a pre-4.3 baseline.")

# ---------------------------------------------------------------------------
# Link llama.cpp static libs into the final shared library
# ---------------------------------------------------------------------------
# SCons wants library names or File nodes for LIBS.  Pass the .a paths
# directly as File nodes so the linker receives them positionally and
# SCons tracks them as build dependencies.
llama_lib_nodes = [File(p) for p in LLAMA_STATIC_LIBS]

env.Append(LIBS=llama_lib_nodes)

# On Linux the linker needs -ldl and -lpthread (pulled in by llama.cpp internals)
if env["platform"] == "linux":
    env.Append(LIBS=["dl", "pthread"])

# ---------------------------------------------------------------------------
# Final shared library
# ---------------------------------------------------------------------------
# .dev doesn't inhibit compatibility, so we don't need to key it.
# .universal just means "compatible with all relevant arches" so we don't need to key it.
suffix = env["suffix"].replace(".dev", "").replace(".universal", "")

lib_filename = "{}{}{}{}".format(
    env.subst("$SHLIBPREFIX"), libname, suffix, env.subst("$SHLIBSUFFIX")
)

library = env.SharedLibrary(
    "bin/{}/{}".format(env["platform"], lib_filename),
    source=sources,
)

copy = env.Install("bin/{}/".format(env["platform"]), library)

default_args = [library, copy]
Default(*default_args)
